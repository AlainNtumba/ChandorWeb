@page "/finance-stats"
@using ChandorAdmin.Components.Dashboard
@using ChandorAdmin.Components.Finance
@using ChandorProject.Shared.DTOs.Finance
@using Syncfusion.Blazor
@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.Charts

<PageTitle>Finance | Chandelier d'Or</PageTitle>

<div class="dashboard-page">
    <DashboardHeader Title="Statistiques Financières"
                     Subtitle="Statistiques et analyse des revenus et des dépenses"
                     Eyebrow="Aperçu des finances">
        <HeaderActions>
            <div title="@_periodLabel">
                @if (_renderRangePicker)
                {
                    <SfDateRangePicker TValue="DateTime"
                                       AllowEdit="false"
                                       ShowClearButton="false"
                                       Format="MM/dd/yyyy"
                                       Placeholder="Select period"
                                       StartDate="@_pickerStart"
                                       EndDate="@_pickerEnd"
                                       Min="@PickerMinDate"
                                       Max="@PickerMaxDate"
                                       Presets="@DateRangePresets">
                        <DateRangePickerEvents TValue="DateTime" ValueChange="OnDateRangeChangeAsync"></DateRangePickerEvents>
                    </SfDateRangePicker>
                }
            </div>
        </HeaderActions>
    </DashboardHeader>

    <section class="dashboard-grid finance-stats-dashboard" aria-label="Finance dashboard grid">
        <div class="dashboard-kpi">
            <StatCard Title="Revenus"
                      Value="@FormatMoney(_summary.TotalIncome)"
                      Hint="Dîmes, offrandes et transferts enregistrés"
                      ValueColor="#4D80F3" />
        </div>

        <div class="dashboard-kpi">
            <StatCard Title="Dépenses"
                      Value="@FormatMoney(_summary.TotalExpenses)"
                      Hint="Dépenses opérationnelles"
                      ValueColor="#FB6D9D" />
        </div>

        <div class="dashboard-kpi">
            <StatCard Title="Balance"
                      Value="@FormatMoney(_summary.Balance)"
                      Hint="Revenus moins dépenses (période)"
                      ValueColor="#81C868" />
        </div>

        <div class="dashboard-kpi">
            <StatCard Title="Transactions"
                      Value="@_summary.TransactionCount.ToString("N0")"
                      Hint="Somme des transactions"
                      ValueColor="#34D3EB" />
        </div>

        <div class="finance-stats-main-row">
            <section class="dashboard-card dashboard-card--chart" aria-label="Income vs expenses chart">
                <div class="dash-panel-heading">
                    <h2 class="dash-panel-heading__title">Revenus vs dépenses</h2>
                    <span class="dash-panel-heading__meta">Six derniers mois (@_barChartPeriodHint) · totaux mensuels</span>
                </div>
                <div class="dash-chart-host">
                    <SfChart @key="ChartRefreshKey"
                             Width="100%"
                             Height="300px"
                             Theme="Theme.Material">
                        <ChartMargin Left="8" Right="36" Top="12" Bottom="8"></ChartMargin>
                        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category"
                                            RangePadding="ChartRangePadding.Additional">
                            <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                            <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                            <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
                        </ChartPrimaryXAxis>
                        <ChartPrimaryYAxis LabelFormat="C0">
                            <ChartAxisMajorGridLines Width="1" DashArray="4"></ChartAxisMajorGridLines>
                            <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                            <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
                        </ChartPrimaryYAxis>
                        <ChartTooltipSettings Enable="true" Shared="true"></ChartTooltipSettings>
                        <ChartLegendSettings Visible="true" Position="LegendPosition.Top" Alignment="@Syncfusion.Blazor.Charts.Alignment.Far"></ChartLegendSettings>
                        <ChartSeriesCollection>
                            <ChartSeries DataSource="@_cashflow"
                                         Name="Income"
                                         XName="@nameof(CashflowSeriesPointDto.MonthLabel)"
                                         YName="@nameof(CashflowSeriesPointDto.Income)"
                                         Type="ChartSeriesType.Column"
                                         Fill="@IncomeSeriesFill">
                                <ChartMarker Visible="false"></ChartMarker>
                            </ChartSeries>
                            <ChartSeries DataSource="@_cashflow"
                                         Name="Expenses"
                                         XName="@nameof(CashflowSeriesPointDto.MonthLabel)"
                                         YName="@nameof(CashflowSeriesPointDto.Expenses)"
                                         Type="ChartSeriesType.Column"
                                         Fill="@ExpenseSeriesFill">
                                <ChartMarker Visible="false"></ChartMarker>
                            </ChartSeries>
                        </ChartSeriesCollection>
                    </SfChart>
                </div>
            </section>

            <section class="dashboard-card dashboard-card--activity" aria-label="Recent activity">
                <div class="dash-panel-heading dash-panel-heading--row">
                    <div>
                        <h2 class="dash-panel-heading__title">Activités financières</h2>
                        <span class="dash-panel-heading__meta">Dernières écritures du registre fictif</span>
                    </div>
                    <span class="dash-chip">Activité récente</span>
                </div>
                <div class="dashboard-feed">
                    @foreach (var row in _recentActivity)
                    {
                        <EventCard Item="row" />
                    }
                </div>
            </section>
        </div>

        <div class="dashboard-pie-row" aria-label="Composition charts">
            <section class="dashboard-card dashboard-card--donut" aria-label="Expense composition">
                <div class="dash-panel-heading">
                    <h2 class="dash-panel-heading__title">Composition des dépenses</h2>
                    <span class="dash-panel-heading__meta">Répartition par catégorie · @_periodLabel</span>
                </div>
                <div class="dash-donut-host">
                    <SfAccumulationChart @key="@($"exp-pie-{ChartRefreshKey}")"
                                         Width="100%"
                                         Height="320px"
                                         Theme="Theme.Material">
                        <AccumulationChartMargin Left="8" Right="8" Top="8" Bottom="24"></AccumulationChartMargin>
                        <AccumulationChartLegendSettings Visible="true"
                                                         Position="LegendPosition.Bottom"
                                                         Alignment="@Syncfusion.Blazor.Charts.Alignment.Center"></AccumulationChartLegendSettings>
                        <AccumulationChartTooltipSettings Enable="true"></AccumulationChartTooltipSettings>
                        <AccumulationChartSeriesCollection>
                            <AccumulationChartSeries DataSource="@_expenseByCategory"
                                                     XName="@nameof(ExpenseCategoryDto.Category)"
                                                     YName="@nameof(ExpenseCategoryDto.Amount)"
                                                     InnerRadius="50%"
                                                     Palettes="@ExpenseCompositionPalette">
                                <AccumulationDataLabelSettings Visible="true"
                                                               Position="AccumulationLabelPosition.Outside"></AccumulationDataLabelSettings>
                            </AccumulationChartSeries>
                        </AccumulationChartSeriesCollection>
                    </SfAccumulationChart>
                </div>
            </section>

            <section class="dashboard-card dashboard-card--donut" aria-label="Income composition">
                <div class="dash-panel-heading">
                    <h2 class="dash-panel-heading__title">Composition des revenus</h2>
                    <span class="dash-panel-heading__meta">Répartition par catégorie · @_periodLabel</span>
                </div>
                <div class="dash-donut-host">
                    <SfAccumulationChart @key="@($"inc-pie-{ChartRefreshKey}")"
                                         Width="100%"
                                         Height="300px"
                                         Theme="Theme.Material">
                        <AccumulationChartMargin Left="8" Right="8" Top="8" Bottom="8"></AccumulationChartMargin>
                        <AccumulationChartLegendSettings Visible="true"
                                                         Position="LegendPosition.Right"
                                                         Alignment="@Syncfusion.Blazor.Charts.Alignment.Center"></AccumulationChartLegendSettings>
                        <AccumulationChartTooltipSettings Enable="true"></AccumulationChartTooltipSettings>
                        <AccumulationChartSeriesCollection>
                            <AccumulationChartSeries DataSource="@_incomeByCategory"
                                                     XName="@nameof(IncomeCategoryDto.Category)"
                                                     YName="@nameof(IncomeCategoryDto.Amount)"
                                                     InnerRadius="50%"
                                                     Palettes="@IncomeCompositionPalette">
                                <AccumulationDataLabelSettings Visible="true"
                                                               Position="AccumulationLabelPosition.Outside"></AccumulationDataLabelSettings>
                            </AccumulationChartSeries>
                        </AccumulationChartSeriesCollection>
                    </SfAccumulationChart>
                </div>
            </section>
        </div>
    </section>
</div>

