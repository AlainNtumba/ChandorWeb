@page "/church-department"

<PageTitle>Départements | Chandelier d'Or</PageTitle>

<div class="container-fluid page-wrapper" style="padding: 0 0 1rem 0">

    <div class="main-container">

        <!-- Header -->
        <div class="header-section p-2 mb-2 bg-secondary text-white fw-bold">
            Département des sœurs
        </div>

        <!-- Main Content -->
        <div class="content-area gap-2">

            <!-- First Row -->
            <div class="row gx-2 gy-0 content-row-top">

                <!-- Large Left Section -->
                <div class="col-md-8 h-100">
                    <div class="content-box">
                        <h5>Main Content Area 1</h5>
                        <p>
                            Any large content added here will scroll inside this box
                            without stretching the page layout.
                        </p>
                    </div>
                </div>

                <!-- Right Sidebar -->
                <div class="col-md-4 h-100">
                    <div class="content-box">
                        <h5>Sidebar 1</h5>
                        <p>
                            Sidebar content remains scrollable inside the fixed area.
                        </p>
                    </div>
                </div>

            </div>

            <!-- Second Row -->
            <div class="row gx-2 gy-0 content-row-bottom">

                <!-- Large Left Section -->
                <div class="col-md-8 h-100">
                    <div class="content-box">
                        <h5>Main Content Area 2</h5>
                        <p>
                            This section also remains fixed and internally scrollable.
                        </p>
                    </div>
                </div>

                <!-- Right Sidebar -->
                <div class="col-md-4 h-100">
                    <div class="content-box">
                        <h5>Sidebar 2</h5>
                        <p>
                            Footer always stays visible on desktop.
                        </p>
                    </div>
                </div>

            </div>

        </div>

    </div>

</div>


