@attribute [AllowAnonymous]
@layout AnonymousLayout
@page "/forgot-password"
@using ChandorAdmin.Components.Auth

<PageTitle>Reset password | Chandelier d'Or</PageTitle>

<ModernForgotPasswordCard Model="Request"
                          FormName="forgot-password-form"
                          OnValidSubmit="SubmitAsync"
                          StatusMessage="@StatusMessage"
                          StatusIsError="@StatusIsError"
                          IsBusy="@IsProcessing"
                          ShowProcessingOverlay="@IsProcessing"
                          LogoSrc="images/ncd_co/logo_2.png"
                          Subtitle="Système de gestion | Chandelier d'Or"
                          LoginHref="login" />
