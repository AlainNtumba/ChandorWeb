@attribute [AllowAnonymous]
@layout AnonymousLayout
@page "/login"
@using ChandorAdmin.Configuration

<PageTitle>Login | Chandelier</PageTitle>

<div class="h-100 gradient-form" style="background-color: #eee;">
    <div class="container py-5 h-100">
        <div class="row d-flex justify-content-center align-items-center h-100">
            <div class="col-xl-10">
                <div class="card rounded-3 text-black">
                    <div class="row g-0">
                        <div class="col-lg-6" style="background-color: #6A239D;">
                            <div class="card-body p-md-5 mx-md-4">

                                <div class="text-center">
                                    <img src="/images/ncd_co/logo_2.png"
                                         style="width: 185px;" alt="logo">
                                </div>

                                <EditForm Model="@User" FormName="@LoginForm" OnValidSubmit="AuthenticateUser">

                                    <DataAnnotationsValidator />

                                    <CustomFormValidator @ref="@FormValidator" />

                                    @if (!string.IsNullOrEmpty(ErrorMsg))
                                    {
                                        <br/>
                                        <div class="mb-4 text-center">
                                            <span class="text-danger">@ErrorMsg</span>
                                        </div>
                                    }

                                    <div data-mdb-input-init class="form-outline mb-4">
                                        <SfTextBox @bind-Value="User.Username" Placeholder="Username" FloatLabelType="FloatLabelType.Auto" />
                                        <span class="c-err-msg">
                                            <ValidationMessage For="@(() => User.Username )" />
                                        </span>
                                    </div>

                                    <div data-mdb-input-init class="form-outline mb-4">
                                        <SfTextBox @bind-Value="User.Password" Type="InputType.Password" Placeholder="Password" FloatLabelType="FloatLabelType.Auto" />
                                        <span class="c-err-msg">
                                            <ValidationMessage For="@(() => User.Password)" />
                                        </span>
                                    </div>

                                    <div class="text-center pt-1 mb-5 pb-1">
                                        <SfButton IsPrimary="true" CssClass="w-100" type="submit" Content="Login" />
                                        <br /><br />
                                        <a class="text-muted" href="/login">Forgot password?</a>
                                    </div>

                                </EditForm>
                                
                                @if (IsProcessing)
                                {
                                    <ResponseLoader ShowSpinner="IsProcessing" />
                                }
                            </div>
                        </div>
                        <div class="col-lg-6 d-flex align-items-center gradient-custom-2">
                            <div class="text-white px-3 py-4 p-md-5 mx-md-4">
                                <h4 class="mb-4">Ministère Nouvelle Cité de David Paroisse Chandelier d'Or</h4>
                                <p class="small mb-0">
                                    Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod
                                    tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud
                                    exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
</div>


<style>
    .e-btn.e-primary, .e-css.e-btn.e-primary {
        background: rgb(89 10 142) !important;
        border-color: rgb(244 196 53) !important;
        color: rgb(245 197 53) !important;
    }
</style>