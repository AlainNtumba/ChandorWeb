@attribute [AllowAnonymous]
@layout AnonymousLayout
@page "/login"
@using ChandorAdmin.Components.Auth

<PageTitle>Login | Chandelier d'Or</PageTitle>

<ModernLoginCard Model="User"
                FormName="@LoginForm"
                OnValidSubmit="AuthenticateUser"
                OnFormValidatorReady="CaptureValidator"
                ErrorMessage="@ErrorMsg"
                IsBusy="@IsProcessing"
                ShowProcessingOverlay="@IsProcessing"
                LogoSrc="/images/ncd_co/logo_2.png"
                 Subtitle="Système de gestion | Chandelier d'Or"
                ForgotPasswordHref="/forgot-password"
                ButtonText="Login" />