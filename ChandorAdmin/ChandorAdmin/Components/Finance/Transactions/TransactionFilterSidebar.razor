@using ChandorAdmin.Components.Dashboard
@using ChandorAdmin.Components.Finance.Management
@using ChandorAdmin.Interfaces.Api
@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Inputs
@using ChandorProject.Shared.DTOs.Finance
@inject IFinanceService FinanceService;

<div class="transactions-filter-root">
    <span id="filter-toggle"
          class="navbar-toggle e-icons e-filter"
          role="button"
          tabindex="0"
          aria-label="Open filters"
          @onclick="ShowFilterMenu"
          @onkeydown="OnFilterToggleKey"></span>

    @if (_mobileDrawerOpen)
    {
        <div class="overlay" @onclick="HideFilterMenu"></div>
    }

    <aside class="transactions-filter-dock @(_mobileDrawerOpen ? "transactions-filter-dock--open" : null)" aria-label="Transaction filters">
        <div class="sidebar-wrapper-filter">
            <div class="filter-head">
                <span class="e-icon filter-icon filter-head-item"></span>
                <span class="filter-txt filter-head-item">Filtres</span>
            </div>
            <div class="expense-filter-container">
                <label class="label-font">Sélectionnez une période</label>
                <div class="filter-date-range filter-item">
                    <SfDateRangePicker TValue="DateTime"
                                       CssClass="DateTime"
                                       ShowClearButton="false"
                                       Format="MM/dd/yyyy"
                                       AllowEdit="false"
                                       EndDate="@EndDate"
                                       StartDate="@StartDate"
                                       Min="@_pickerMinDate"
                                       Max="@_pickerMaxDate"
                                       Presets="@_transactionDateRangePresets">
                        <DateRangePickerEvents TValue="DateTime" ValueChange="DateRangeChanged"></DateRangePickerEvents>
                    </SfDateRangePicker>
                </div>
                <label class="label-font">Catégorie</label>
                <div class="category filter-item">
                    <SfMultiSelect TValue="string[]"
                                   TItem="FilterCategoryOption"
                                   DataSource="@_filterCategoryList"
                                   Mode="VisualMode.Box"
                                   Placeholder="Sélectionnez les catégories"
                                   HideSelectedItem="true"
                                   ClosePopupOnSelect="false">
                        <MultiSelectEvents TValue="string[]"
                                           TItem="FilterCategoryOption"
                                           OnValueSelect="CategorySelect"
                                           OnValueRemove="CategoryRemove"
                                           Cleared="ClearHandler">
                        </MultiSelectEvents>
                        <MultiSelectFieldSettings Text="Text" Value="Value"></MultiSelectFieldSettings>
                    </SfMultiSelect>
                </div>
                <label class="label-font bottom-align">Cashflow</label>
                <div class="cashflow filter-item">
                    <SfCheckBox TChecked="bool" Label="Entrée" @bind-Checked="_incomeChecked" CssClass="TransactionType" ValueChange="OnFilterControlChanged"></SfCheckBox>
                    <SfCheckBox TChecked="bool" Label="Sortie" @bind-Checked="_expenseChecked" CssClass="TransactionType" ValueChange="OnFilterControlChanged"></SfCheckBox>
                </div>
                @if (_accountFilterOptions.Count > 0)
                {
                    <label class="label-font bottom-align">Comptes</label>
                    <div class="paymentModes filter-item">
                        @foreach (var account in _accountFilterOptions)
                        {
                            <SfCheckBox TChecked="bool"
                                        Label="@account"
                                        Checked="@IsAccountChecked(account)"
                                        CssClass="PaymentMode"
                                        ValueChange="@(args => OnAccountFilterChanged(account, args))">
                            </SfCheckBox>
                            <br />
                        }
                    </div>
                }
                <div>
                    <label class="label-font">Montant</label>
                    <div class="amount-filter">
                        <div class="min-numeric amt-filter">
                            <label class="inlineAlign minLabel">Min :</label>
                            <SfNumericTextBox TValue="double?" CssClass="inlineAlign" Width="55px" Format="c0" ShowSpinButton="false" @bind-Value="_minAmount" Min="0">
                                <NumericTextBoxEvents TValue="double?" ValueChange="OnFilterControlChanged"></NumericTextBoxEvents>
                            </SfNumericTextBox>
                        </div>
                        <span class="amt-filter separateLine"></span>
                        <div class="max-numeric amt-filter">
                            <label class="inlineAlign maxLabel">Max :</label>
                            <SfNumericTextBox TValue="double?" CssClass="inlineAlign" Width="55px" Format="c0" ShowSpinButton="false" @bind-Value="_maxAmount" Min="0">
                                <NumericTextBoxEvents TValue="double?" ValueChange="OnFilterControlChanged"></NumericTextBoxEvents>
                            </SfNumericTextBox>
                        </div>
                    </div>
                </div>
                <label class="label-font bottom-align">Gérer les comptes et types de transactions</label>
                <div class="transaction-manage-actions">
                    <div><SfButton Content="Comptes" OnClick="OpenAccountsPanelAsync" /></div>
                    <div><SfButton Content="Type de Revenu" OnClick="OpenIncomeTypesPanelAsync" /></div>
                    <div><SfButton Content="Type de Dépenses" OnClick="OpenExpenseTypesPanelAsync" /></div>
                </div>
            </div>
        </div>
    </aside>
</div>

<AccountGridPanel @ref="_accountPanel" />
<IncomeTypeGridPanel @ref="_incomeTypePanel" />
<ExpenseTypeGridPanel @ref="_expenseTypePanel" />

@code {
    public TransactionGridPanel? ContentRef { get; set; }

    AccountGridPanel? _accountPanel;
    IncomeTypeGridPanel? _incomeTypePanel;
    ExpenseTypeGridPanel? _expenseTypePanel;

    readonly List<Presets> _transactionDateRangePresets = DashboardDateRangePresets.StandardThreePresets();

    public DateTime StartDate { get; private set; }
    public DateTime EndDate { get; private set; }

    bool _mobileDrawerOpen;
    bool _incomeChecked = true;
    bool _expenseChecked = true;
    double? _minAmount;
    double? _maxAmount;
    readonly List<string> _categoryValues = new();
    readonly HashSet<string> _selectedAccounts = new(StringComparer.OrdinalIgnoreCase);
    List<string> _accountFilterOptions = new();
    List<FilterCategoryOption> _filterCategoryList = new();
    DateTime _pickerMinDate => new(2015, 1, 1, 0, 0, 0);
    DateTime _pickerMaxDate => new(DateTime.Today.Year + 5, 12, 31, 23, 59, 59);

    protected override void OnInitialized()
    {
        (StartDate, EndDate) = TransactionGridPanel.GetCalendarMonthBounds(DateTime.Today);
        _minAmount = 0;
        _maxAmount = null;
    }

    public void SetDateRange(DateTime start, DateTime end)
    {
        StartDate = start;
        EndDate = end;
    }

    internal void ShowFilterMenu()
    {
        _mobileDrawerOpen = true;
        StateHasChanged();
    }

    void HideFilterMenu()
    {
        _mobileDrawerOpen = false;
        StateHasChanged();
    }

    Task OpenAccountsPanelAsync() => _accountPanel?.ShowAsync() ?? Task.CompletedTask;

    Task OpenIncomeTypesPanelAsync() => _incomeTypePanel?.ShowAsync() ?? Task.CompletedTask;

    Task OpenExpenseTypesPanelAsync() => _expenseTypePanel?.ShowAsync() ?? Task.CompletedTask;

    void OnFilterToggleKey(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            ShowFilterMenu();
    }

    public void CategorySelect(SelectEventArgs<FilterCategoryOption> args)
    {
        if (args.ItemData?.Value is { } v)
            _categoryValues.Add(v);
        UpdateGrid();
    }

    public void CategoryRemove(RemoveEventArgs<FilterCategoryOption> args)
    {
        if (args.ItemData?.Value is { } v)
            _categoryValues.Remove(v);
        UpdateGrid();
    }

    void ClearHandler()
    {
        _categoryValues.Clear();
        UpdateGrid();
    }

    async Task DateRangeChanged(RangePickerEventArgs<DateTime> args)
    {
        StartDate = args.StartDate;
        EndDate = args.EndDate;

        if (ContentRef is not null)
        {
            await ContentRef.LoadTransactionsAsync(StartDate, EndDate);
            RebuildCategoryList();
            UpdateGrid();
            ContentRef.UpdateTotalBalance();
        }
    }

    void OnFilterControlChanged() => UpdateGrid();

    bool IsAccountChecked(string account) =>
        _selectedAccounts.Count == 0 || _selectedAccounts.Contains(account);

    void OnAccountFilterChanged(string account, Syncfusion.Blazor.Buttons.ChangeEventArgs<bool> args)
    {
        if (_accountFilterOptions.Count == 0)
            return;

        if (_selectedAccounts.Count == 0)
            _selectedAccounts.UnionWith(_accountFilterOptions);

        if (args.Checked)
            _selectedAccounts.Add(account);
        else
            _selectedAccounts.Remove(account);

        if (_selectedAccounts.Count == _accountFilterOptions.Count)
            _selectedAccounts.Clear();

        UpdateGrid();
    }

    public void RebuildCategoryList()
    {
        if (ContentRef is null)
            return;

        var rows = ContentRef.AllTransactions;
        _filterCategoryList = rows
            .Select(r => r.TransactionCategory)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c)
            .Select(c => new FilterCategoryOption { Text = c, Value = c })
            .ToList();

        _accountFilterOptions = rows
            .Select(r => r.AccountName)
            .Where(a => !string.IsNullOrWhiteSpace(a))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(a => a)
            .ToList();

        _selectedAccounts.Clear();
        MinMaxAmount(rows);
    }

    void MinMaxAmount(IEnumerable<TransactionDto> rows)
    {
        var slice = rows.ToList();
        if (slice.Count > 0)
        {
            _minAmount = (double)slice.Min(s => s.Amount);
            _maxAmount = (double)slice.Max(s => s.Amount);
        }
    }

    public IEnumerable<TransactionDto> RefreshData()
    {
        if (ContentRef is null)
            return Array.Empty<TransactionDto>();

        IEnumerable<TransactionDto> rows = ContentRef.AllTransactions;

        var min = (decimal)(_minAmount ?? 0);
        var max = _maxAmount.HasValue ? (decimal)_maxAmount.Value : decimal.MaxValue;
        rows = rows.Where(s => s.Amount >= min && s.Amount <= max);

        if (_incomeChecked || _expenseChecked)
        {
            if (_incomeChecked && _expenseChecked)
                rows = rows.Where(s => s.TransactionType is "Income" or "Expense");
            else if (_incomeChecked)
                rows = rows.Where(s => s.TransactionType == "Income");
            else if (_expenseChecked)
                rows = rows.Where(s => s.TransactionType == "Expense");
        }

        if (_selectedAccounts.Count > 0)
            rows = rows.Where(s => _selectedAccounts.Contains(s.AccountName));

        if (_categoryValues.Count > 0)
            rows = rows.Where(s => _categoryValues.Contains(s.TransactionCategory));

        return rows.OrderByDescending(e => e.TransactionDate).ToList();
    }

    public void UpdateGrid()
    {
        if (ContentRef is null)
            return;
        ContentRef.GridRefresh(RefreshData());
    }

    public void ApplyToolbarTypeFilter(string type)
    {
        switch (type)
        {
            case "Income":
                _incomeChecked = true;
                _expenseChecked = false;
                break;
            case "Expense":
                _incomeChecked = false;
                _expenseChecked = true;
                break;
            default:
                _incomeChecked = true;
                _expenseChecked = true;
                break;
        }

        UpdateGrid();
        StateHasChanged();
    }

    public sealed class FilterCategoryOption
    {
        public string Text { get; set; } = "";
        public string Value { get; set; } = "";
    }
}
