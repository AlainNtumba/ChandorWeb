@using System.ComponentModel.DataAnnotations
@using ChandorProject.Shared.DTOs.Member

<section class="modern-login" aria-label="Reset password">
    <div class="modern-login__bg" aria-hidden="true">
        <div class="modern-login__orb modern-login__orb--one"></div>
        <div class="modern-login__orb modern-login__orb--two"></div>
        <div class="modern-login__orb modern-login__orb--three"></div>
    </div>

    <div class="modern-login__container">
        <div class="modern-login__card" role="region" aria-label="Reset password form">
            <div class="modern-login__shine" aria-hidden="true"></div>

            <div class="modern-login__header">
                <div class="modern-login__logo" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(LogoSrc))
                    {
                        <img class="modern-login__logo-img" src="@LogoSrc" alt="" />
                    }
                    else
                    {
                        <span class="modern-login__logo-mark"></span>
                    }
                </div>
                <h1 class="modern-login__title">@Title</h1>
                <p class="modern-login__subtitle">@Subtitle</p>
                @if (!string.IsNullOrWhiteSpace(Hint))
                {
                    <p class="modern-login__hint">@Hint</p>
                }
            </div>

            <EditForm Model="@Model" FormName="@FormName" OnValidSubmit="@OnValidSubmit">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    @if (StatusIsError)
                    {
                        <div class="modern-login__error" role="alert">
                            @StatusMessage
                        </div>
                    }
                    else
                    {
                        <div class="modern-login__success" role="status">
                            @StatusMessage
                        </div>
                    }
                }

                <div class="modern-login__field">
                    <label class="modern-login__label" for="@EmailInputId">Email</label>
                    <div class="modern-login__control">
                        <span class="modern-login__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5L4 8V6l8 5 8-5v2Z" />
                            </svg>
                        </span>
                        <input id="@EmailInputId"
                               class="modern-login__input"
                               autocomplete="email"
                               inputmode="email"
                               aria-describedby="@EmailHelpId"
                               placeholder="Email"
                               @bind="Model.Email" />
                    </div>
                    <div id="@EmailHelpId" class="modern-login__validation">
                        <ValidationMessage For="@(() => Model.Email)" />
                    </div>
                </div>

                <div class="modern-login__field">
                    <label class="modern-login__label" for="@PhoneInputId">Phone number</label>
                    <div class="modern-login__control">
                        <span class="modern-login__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.07 21 3 13.93 3 5a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.59a1 1 0 0 1-.25 1l-2.2 2.2Z" />
                            </svg>
                        </span>
                        <input id="@PhoneInputId"
                               class="modern-login__input"
                               type="tel"
                               autocomplete="tel"
                               inputmode="tel"
                               aria-describedby="@PhoneHelpId"
                               placeholder="Phone number"
                               @bind="Model.PhoneNumber" />
                    </div>
                    <div id="@PhoneHelpId" class="modern-login__validation">
                        <ValidationMessage For="@(() => Model.PhoneNumber)" />
                    </div>
                </div>

                <div class="modern-login__row modern-login__row--center">
                    <a class="modern-login__link" href="@LoginHref">Back to login</a>
                </div>

                <button type="submit" class="modern-login__button" disabled="@IsBusy">
                    <span class="modern-login__button-label">@ButtonText</span>
                    @if (IsBusy)
                    {
                        <span class="modern-login__spinner" aria-hidden="true"></span>
                    }
                </button>
            </EditForm>

            @if (ShowProcessingOverlay)
            {
                <div class="modern-login__overlay" aria-live="polite" aria-busy="true">
                    <ResponseLoader ShowSpinner="true" />
                </div>
            }
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public RequestResetPasswordDto Model { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback OnValidSubmit { get; set; }

    [Parameter] public string FormName { get; set; } = "forgot-password-form";
    [Parameter] public string Title { get; set; } = "Reset password";
    [Parameter] public string Subtitle { get; set; } = "Système de gestion | Chandelier d'Or";
    [Parameter] public string? Hint { get; set; } =
        "Saisissez votre email ou téléphone pour recevoir les instructions de réinitialisation.";
    [Parameter] public string ButtonText { get; set; } = "Send reset request";
    [Parameter] public string LoginHref { get; set; } = "login";
    [Parameter] public string? StatusMessage { get; set; }
    [Parameter] public bool StatusIsError { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public bool ShowProcessingOverlay { get; set; }
    [Parameter] public string? LogoSrc { get; set; }

    private string EmailInputId { get; } = $"forgot-email-{Guid.NewGuid():N}";
    private string PhoneInputId { get; } = $"forgot-phone-{Guid.NewGuid():N}";
    private string EmailHelpId { get; } = $"forgot-email-help-{Guid.NewGuid():N}";
    private string PhoneHelpId { get; } = $"forgot-phone-help-{Guid.NewGuid():N}";
}
